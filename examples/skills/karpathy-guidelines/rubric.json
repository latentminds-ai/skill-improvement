{
  "name": "Karpathy Guidelines Skill Rubric",
  "version": "1.0.0",
  "totalPoints": 30,
  "tiers": [
    {
      "id": 0,
      "name": "Basic Structure",
      "points": 6,
      "criteria": [
        {
          "id": "0.1",
          "name": "SKILL.md exists",
          "type": "deterministic",
          "method": "files",
          "require": ["SKILL.md"],
          "points": 2
        },
        {
          "id": "0.2",
          "name": "README.md exists",
          "type": "deterministic",
          "method": "files",
          "require": ["README.md"],
          "points": 2
        },
        {
          "id": "0.3",
          "name": "License defined",
          "type": "deterministic",
          "method": "skillFrontmatter",
          "require": ["license"],
          "points": 2
        }
      ]
    },
    {
      "id": 1,
      "name": "Agent Readiness",
      "points": 8,
      "criteria": [
        {
          "id": "1.1",
          "name": "Name matches directory",
          "type": "deterministic",
          "method": "skillFrontmatter",
          "checkNameMatch": true,
          "points": 2
        },
        {
          "id": "1.2",
          "name": "Description is clear",
          "type": "deterministic",
          "method": "skillFrontmatter",
          "require": ["description"],
          "descriptionMinLength": 20,
          "points": 2
        },
        {
          "id": "1.3",
          "name": "Governance metadata present",
          "type": "deterministic",
          "method": "skillFrontmatter",
          "require": ["metadata.tier", "metadata.owner", "metadata.platforms"],
          "points": 2
        },
        {
          "id": "1.4",
          "name": "Platform coverage documented",
          "type": "deterministic",
          "method": "skillFrontmatter",
          "platformsCount": 1,
          "points": 2
        }
      ]
    },
    {
      "id": 2,
      "name": "Content Quality",
      "points": 10,
      "criteria": [
        {
          "id": "2.1",
          "name": "Clear output contract",
          "type": "deterministic",
          "method": "skillContent",
          "check": "outputContract",
          "points": 3
        },
        {
          "id": "2.2",
          "name": "Failure modes documented",
          "type": "deterministic",
          "method": "skillContent",
          "check": "failureModes",
          "points": 2
        },
        {
          "id": "2.3",
          "name": "Examples or references",
          "type": "deterministic",
          "method": "skillContent",
          "check": "composability",
          "points": 3
        },
        {
          "id": "2.4",
          "name": "Well-structured sections",
          "type": "deterministic",
          "method": "skillContent",
          "check": "sectionStructure",
          "minHeadings": 3,
          "points": 2
        }
      ]
    },
    {
      "id": 3,
      "name": "Verification Gates",
      "points": 6,
      "criteria": [
        {
          "id": "3.1",
          "name": "Success criteria defined",
          "type": "deterministic",
          "method": "skillContent",
          "check": "deterministicGates",
          "pattern": "verify|test|check",
          "points": 3
        },
        {
          "id": "3.2",
          "name": "Tradeoffs documented",
          "type": "deterministic",
          "method": "skillContent",
          "check": "failureModes",
          "pattern": "tradeoff|caution|judgment",
          "points": 3
        }
      ]
    }
  ],
  "grading": {
    "A": { "min": 27, "max": 30, "label": "Excellent" },
    "B": { "min": 22, "max": 26, "label": "Good" },
    "C": { "min": 17, "max": 21, "label": "Satisfactory" },
    "D": { "min": 12, "max": 16, "label": "Needs Work" },
    "F": { "min": 0, "max": 11, "label": "Incomplete" }
  }
}
